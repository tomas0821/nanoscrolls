&CONTROL
    calculation = 'relax'
    prefix = 'alcl4'
    pseudo_dir = '/home/tomas.rojas_s/pseudo/'
    outdir = './out'
    nstep = 200
    etot_conv_thr = 1.0D-5
    forc_conv_thr = 1.0D-4
/
&SYSTEM
    ibrav = 0
    nat = 5
    ntyp = 2
    ecutwfc = 45.0
    ecutrho = 360.0
    occupations = 'smearing'
    smearing = 'mp'
    degauss = 0.02
    vdw_corr = 'dft-d3'
/
&ELECTRONS
    conv_thr = 1.0D-8
    mixing_beta = 0.7
/
&IONS
    ion_dynamics = 'bfgs'
/
&CELL
/

